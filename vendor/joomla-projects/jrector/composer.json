{
  "name": "joomla-projects/jrector",
  "description": "Rector rules to upgrade Joomla extension codes",
  "prefer-stable": true,
  "minimum-stability": "dev",
  "license": "GPL-2.0-or-later",
  "version": "0.1.0",
  "config": {
    "optimize-autoloader": true
  },
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "webmozart/assert": "^1.11.0"
  },
  "require-dev": {
    "rector/rector": "^2.0",
    "joomla-projects/typehints": "*",
    "friendsofphp/php-cs-fixer": "^3.94.2",
    "phpunit/phpunit": "^10.0 | ^11.0",
    "phpstan/phpstan-deprecation-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Joomla\\Rector\\": "rules",
      "Joomla\\Rector\\Tests\\": "rules-tests"
    }
  }
}
